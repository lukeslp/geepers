{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dr.eamer.dev/geepers/schemas/skill-manifest.schema.json",
  "title": "Geepers Skill Manifest",
  "type": "object",
  "required": ["version", "canonical_repo", "skills"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "manifest_name": {
      "type": "string"
    },
    "canonical_repo": {
      "type": "string"
    },
    "canonical_root": {
      "type": "string"
    },
    "defaults": {
      "type": "object"
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "source_path", "bundles"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "source_path": {
            "type": "string"
          },
          "bundles": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9-]+$"
            }
          },
          "platforms": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["claude", "codex", "gemini", "manus", "clawhub"]
            }
          },
          "description": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["active", "legacy", "experimental", "deprecated"]
          },
          "allow_legacy_name": {
            "type": "boolean"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
